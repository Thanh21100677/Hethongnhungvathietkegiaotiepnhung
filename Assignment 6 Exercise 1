#include <stdio.h>
#include <string.h>

int strend(char *s, char *t) {
    int len_s = strlen(s);
    int len_t = strlen(t);

    if (len_t > len_s) return 0;

    s = s + (len_s - len_t);

    while (*s && *t) {
        if (*s != *t) return 0;
        s++;
        t++;
    }
    return 1;
}

int main() {
    printf("%d\n", strend("hello", "lo"));  // 1
    printf("%d\n", strend("hello", "he"));  // 0
}
